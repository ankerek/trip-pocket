# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit the real secrets.
#
# Source the file before running a local release build or `expo prebuild`:
#   export $(cat .env.local | xargs)
#
# Both values mirror the project-scoped EAS secrets used by EAS builds:
#   eas secret:list

# Sentry build-time auth token (Organization Token, org:ci scope).
# Used by the @sentry/react-native Xcode build phase to upload JS
# sourcemaps and native dSYMs during a local Release archive.
# Create at: https://sentry.io/settings/<org>/developer-settings/organization-tokens/
SENTRY_AUTH_TOKEN=sntrys_paste_token_here

# Sentry DSN — public, baked into the JS bundle at Metro bundle time
# via process.env access in lib/observability/sentry.ts.
# Read from: https://sentry.io/settings/<org>/projects/<project>/keys/
EXPO_PUBLIC_SENTRY_DSN=https://paste_dsn_here

# RevenueCat iOS Public SDK Key (Project → API keys in dashboard).
# Stored as an EAS Secret for production builds.
EXPO_PUBLIC_RC_IOS_API_KEY=
# Same shape, but for the dev RC project. Used only when the build is
# APP_VARIANT=development (com.trippocket.app.dev). Falls back to the prod
# key above if unset, so existing devs keep working.
EXPO_PUBLIC_RC_IOS_API_KEY_DEV=
