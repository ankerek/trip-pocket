{
  "expo": {
    "name": "Trip Pocket",
    "slug": "trip-pocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trippocket",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.trippocket.app",
      "icon": "./assets/AppIcon.icon",
      "supportsTablet": false,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.trippocket.shared"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "WL5ALL46C4"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "./plugins/with-share-extension",
      "./plugins/with-resource-bundle-signing-fix",
      [
        "expo-image-picker",
        {
          "photosPermission": "Trip Pocket needs to read photos so you can add screenshots to your trips."
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2dee30ac-eb35-4cc6-80d7-4e6a664237b5",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "TripPocketShare",
                  "bundleIdentifier": "com.trippocket.app.share",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.trippocket.shared"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "ankerek"
  }
}
